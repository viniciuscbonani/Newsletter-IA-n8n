      "parameters": {
        "jsCode": "const categorias = $input.first().json.categoria;\nconst counts = {};\n\nfor (const cat of categorias) {\n  // O .trim() remove espaços em branco no início e no fim da string, prevenindo erros como categorias duplicadas\n  const categoria = (cat || \"Outros\").trim();\n  counts[categoria] = (counts[categoria] || 0) + 1;\n}\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    categoryCount: counts\n  }\n}];"
